{
  "version": 1,
  "camera": {
    "quality": 12,
    "framesize": 10,
    "flip_horizontal": false,
    "flip_vertical": false,
    "brightness": 0,
    "contrast": 0,
    "saturation": 0
  },
  "led_ring": {
    "enabled": true,
    "data_pin": 38,
    "count": 40,
    "brightness": 10,
    "color_red": 255,
    "color_green": 255,
    "color_blue": 255
  },
  "rotary_encoder": {
    "enabled": true,
    "clk_pin": 21,
    "dt_pin": 20,
    "sw_pin": 19
  },
  "thermal_printer": {
    "enabled": true,
    "uart_port": 1,
    "tx_pin": 41,
    "rx_pin": 42,
    "rts_pin": 2,
    "baud_rate": 9600,
    "max_print_width": 32
  },
  "system": {
    "device_name": "ESP32-Camera",
    "led_enabled": true,
    "http_port": 80
  },
  "server": {
    "upload_url": "http://192.168.1.100:5000/api/capture",
    "upload_enabled": true,
    "upload_interval_seconds": 30
  },
  "ota": {
    "github_owner": "coencoensmeets",
    "github_repo": "Poem_cam",
    "testing_branch": "main",
    "update_channel": 0,
    "auto_check": false
  }
}
