*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
*.egg
venv/
env/
ENV/
.venv

# Flask uploads and generated content
flask_server/uploads/*
!flask_server/uploads/.gitkeep
flask_server/static/uploads/*
!flask_server/static/uploads/.gitkeep
*_poem.json
*_poems.json

